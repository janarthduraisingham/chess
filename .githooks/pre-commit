#!/bin/sh
# Pre-commit hook to prevent accidental commits of data files

echo "pre-commit commencing"

# Check if any data files are being committed
DATA_FILES=".csv .xlsx .xls .xlsm"

for file in $DATA_FILES; do
    if git diff --cached --name-only | grep -q ".*${file}$"; then
        echo "⚠️  ERROR: You're about to commit a file with extension: ${file}"
        echo ""
        echo "This file should never be committed as it may contain personal information."
        echo "❌ Commit aborted."
        exit 1
    fi

    echo "✅ No ${file} files to committed"
done

echo "pre-commit complete"